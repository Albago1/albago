{
  "name": "albago-shell",
  "version": "0.1.0",
  "private": true,
  "description": "Capacitor store shells for AlbaGo (master plan APP-2). Remote URL mode: the shell wraps https://www.albago.org — the product keeps shipping on the web side.",
  "scripts": {
    "sync": "cap sync",
    "open:android": "cap open android",
    "open:ios": "cap open ios",
    "assets": "capacitor-assets generate --iconBackgroundColor '#0A0A0A' --iconBackgroundColorDark '#0A0A0A' --splashBackgroundColor '#050505' --splashBackgroundColorDark '#050505'"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/push-notifications": "^8.1.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.4.1",
    "typescript": "^5.9.3"
  }
}
